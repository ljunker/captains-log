#!/usr/bin/env bash

set -euo pipefail

usage() {
    cat <<'EOF'
Usage:
  ./pushtag patch
  ./pushtag minor
  ./pushtag major
  ./pushtag v1.2.3
  ./pushtag --dry-run patch
  ./pushtag --remote upstream minor

Creates an annotated git tag and pushes it to the selected remote.
EOF
}

die() {
    printf 'Error: %s\n' "$1" >&2
    exit 1
}

is_semver_tag() {
    [[ "$1" =~ ^v([0-9]+)\.([0-9]+)\.([0-9]+)$ ]]
}

next_version_from() {
    local current="$1"
    local bump="$2"
    local major minor patch

    if ! [[ "$current" =~ ^v([0-9]+)\.([0-9]+)\.([0-9]+)$ ]]; then
        die "Invalid semantic version tag: $current"
    fi

    major="${BASH_REMATCH[1]}"
    minor="${BASH_REMATCH[2]}"
    patch="${BASH_REMATCH[3]}"

    case "$bump" in
        patch)
            patch=$((patch + 1))
            ;;
        minor)
            minor=$((minor + 1))
            patch=0
            ;;
        major)
            major=$((major + 1))
            minor=0
            patch=0
            ;;
        *)
            die "Unknown bump type: $bump"
            ;;
    esac

    printf 'v%s.%s.%s\n' "$major" "$minor" "$patch"
}

ensure_git_repo() {
    git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "This script must be run inside a git repository."
}

select_remote() {
    local requested="${1:-}"

    if [[ -n "$requested" ]]; then
        git remote get-url "$requested" >/dev/null 2>&1 || die "Git remote '$requested' does not exist."
        printf '%s\n' "$requested"
        return
    fi

    if git remote get-url origin >/dev/null 2>&1; then
        printf 'origin\n'
        return
    fi

    requested="$(git remote | head -n 1 || true)"
    [[ -n "$requested" ]] || die "No git remote found. Use --remote after configuring one."
    printf '%s\n' "$requested"
}

latest_semver_tag() {
    git tag --list 'v[0-9]*.[0-9]*.[0-9]*' --sort=-v:refname | head -n 1
}

ensure_tag_absent() {
    local tag="$1"
    if git rev-parse -q --verify "refs/tags/$tag" >/dev/null 2>&1; then
        die "Git tag '$tag' already exists."
    fi
}

main() {
    local remote=""
    local dry_run=0
    local mode=""

    while (($#)); do
        case "$1" in
            --dry-run)
                dry_run=1
                shift
                ;;
            --remote)
                shift
                (($#)) || die "--remote requires a value."
                remote="$1"
                shift
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            patch|minor|major)
                [[ -z "$mode" ]] || die "Only one version argument is allowed."
                mode="$1"
                shift
                ;;
            v*)
                [[ -z "$mode" ]] || die "Only one version argument is allowed."
                is_semver_tag "$1" || die "Manual version must match vMAJOR.MINOR.PATCH."
                mode="$1"
                shift
                ;;
            *)
                usage >&2
                die "Unknown argument: $1"
                ;;
        esac
    done

    [[ -n "$mode" ]] || die "Missing version argument."

    ensure_git_repo
    remote="$(select_remote "$remote")"

    if ((dry_run == 0)); then
        git fetch --tags "$remote"
    fi

    local tag
    local latest_tag

    if [[ "$mode" =~ ^(patch|minor|major)$ ]]; then
        latest_tag="$(latest_semver_tag)"
        if [[ -z "$latest_tag" ]]; then
            latest_tag="v0.0.0"
        fi
        tag="$(next_version_from "$latest_tag" "$mode")"
    else
        tag="$mode"
    fi

    ensure_tag_absent "$tag"

    printf 'Remote: %s\n' "$remote"
    if [[ -n "${latest_tag:-}" ]]; then
        printf 'Latest tag: %s\n' "$latest_tag"
    fi
    printf 'New tag: %s\n' "$tag"

    if ((dry_run)); then
        printf 'Dry run: no tag created and nothing pushed.\n'
        exit 0
    fi

    git tag -a "$tag" -m "Release $tag"
    git push "$remote" "$tag"

    printf 'Created and pushed %s to %s.\n' "$tag" "$remote"
}

main "$@"
