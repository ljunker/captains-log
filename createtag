#!/usr/bin/env bash

set -euo pipefail

usage() {
    cat <<'EOF'
Usage:
  ./createtag patch
  ./createtag minor
  ./createtag major
  ./createtag v1.2.3
  ./createtag --dry-run patch

Creates an annotated local git tag.
EOF
}

die() {
    printf 'Error: %s\n' "$1" >&2
    exit 1
}

is_semver_tag() {
    [[ "$1" =~ ^v([0-9]+)\.([0-9]+)\.([0-9]+)$ ]]
}

next_version_from() {
    local current="$1"
    local bump="$2"
    local major minor patch

    if ! [[ "$current" =~ ^v([0-9]+)\.([0-9]+)\.([0-9]+)$ ]]; then
        die "Invalid semantic version tag: $current"
    fi

    major="${BASH_REMATCH[1]}"
    minor="${BASH_REMATCH[2]}"
    patch="${BASH_REMATCH[3]}"

    case "$bump" in
        patch)
            patch=$((patch + 1))
            ;;
        minor)
            minor=$((minor + 1))
            patch=0
            ;;
        major)
            major=$((major + 1))
            minor=0
            patch=0
            ;;
        *)
            die "Unknown bump type: $bump"
            ;;
    esac

    printf 'v%s.%s.%s\n' "$major" "$minor" "$patch"
}

ensure_git_repo() {
    git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "This script must be run inside a git repository."
}

latest_semver_tag() {
    git tag --list 'v[0-9]*.[0-9]*.[0-9]*' --sort=-v:refname | head -n 1
}

ensure_tag_absent() {
    local tag="$1"
    if git rev-parse -q --verify "refs/tags/$tag" >/dev/null 2>&1; then
        die "Git tag '$tag' already exists."
    fi
}

main() {
    local dry_run=0
    local mode=""

    while (($#)); do
        case "$1" in
            --dry-run)
                dry_run=1
                shift
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            patch|minor|major)
                [[ -z "$mode" ]] || die "Only one version argument is allowed."
                mode="$1"
                shift
                ;;
            v*)
                [[ -z "$mode" ]] || die "Only one version argument is allowed."
                is_semver_tag "$1" || die "Manual version must match vMAJOR.MINOR.PATCH."
                mode="$1"
                shift
                ;;
            *)
                usage >&2
                die "Unknown argument: $1"
                ;;
        esac
    done

    [[ -n "$mode" ]] || die "Missing version argument."

    ensure_git_repo

    local tag
    local latest_tag

    if [[ "$mode" =~ ^(patch|minor|major)$ ]]; then
        latest_tag="$(latest_semver_tag)"
        if [[ -z "$latest_tag" ]]; then
            latest_tag="v0.0.0"
        fi
        tag="$(next_version_from "$latest_tag" "$mode")"
    else
        tag="$mode"
    fi

    ensure_tag_absent "$tag"

    if [[ -n "${latest_tag:-}" ]]; then
        printf 'Latest tag: %s\n' "$latest_tag"
    fi
    printf 'New tag: %s\n' "$tag"

    if ((dry_run)); then
        printf 'Dry run: no tag created.\n'
        exit 0
    fi

    git tag -a "$tag" -m "Release $tag"

    printf 'Created local tag %s.\n' "$tag"
}

main "$@"
